<Window x:Class="OP_Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OP Windows Ultimate v2.0" Height="850" Width="520"
        Background="#F4F4F4" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="OP Windows" FontSize="32" FontWeight="ExtraBold" 
                           Margin="0,0,0,5" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                <TextBlock Text="Инструмент оптимизации системы" FontSize="14" Foreground="#666" 
                           Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <!-- Внешний вид -->
                <GroupBox Header="Внешний вид и интерфейс" Margin="0,0,0,10" Padding="10">
                    <UniformGrid Columns="2">
                        <Button Content="Убрать стрелки" Click="RemoveArrows_Click" Margin="5" Height="35" Background="#FFF9C4" ToolTip="Делает ярлыки чистыми без иконок стрелочек"/>
                        <Button Content="Вернуть стрелки" Click="RestoreArrows_Click" Margin="5" Height="35" ToolTip="Возвращает стандартные стрелки на ярлыки"/>
                        <Button Content="Меню Win 10" Click="MenuClassic_Click" Margin="5" Height="35" ToolTip="Возвращает классическое контекстное меню"/>
                        <Button Content="Меню Win 11" Click="MenuDefault_Click" Margin="5" Height="35" ToolTip="Возвращает стандартное меню Windows 11"/>
                    </UniformGrid>
                </GroupBox>

                <!-- Скорость загрузки -->
                <GroupBox Header="Оптимизация загрузки (Fix 42 сек)" Margin="0,0,0,10" Padding="10" Background="#E8F5E9">
                    <StackPanel>
                        <Button Content="УСКОРИТЬ ЗАПУСК СИСТЕМЫ" Click="RemoveStartupDelay_Click" Margin="5" Height="45" FontWeight="Bold" ToolTip="Убирает искусственную задержку запуска рабочего стола"/>
                        <Button Content="СБРОС КЭША ИКОНОК" Click="ResetIconCache_Click" Margin="5" Height="35" ToolTip="Исправляет черные квадраты или белые значки"/>
                    </StackPanel>
                </GroupBox>

                <!-- Приватность и Сеть -->
                <GroupBox Header="Конфиденциальность и Сеть" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <UniformGrid Columns="2">
                            <Button Content="DNS Cloudflare" Click="SetFastDNS_Click" Margin="5" Height="35" Background="#E3F2FD" ToolTip="Ускоряет отклик интернета через 1.1.1.1"/>
                            <Button Content="DNS по умолч." Click="SetAutoDNS_Click" Margin="5" Height="35" ToolTip="Возвращает настройки DNS от провайдера"/>
                        </UniformGrid>
                        <Separator Margin="0,10"/>
                        <UniformGrid Columns="2">
                            <Button Content="Оптимизировать приватность" Click="DisableTelemetry_Click" Margin="5" Height="35" Background="#FFEBEE" ToolTip="Отключает отправку диагностических данных в Microsoft"/>
                            <Button Content="Включить отчеты" Click="EnableTelemetry_Click" Margin="5" Height="35" ToolTip="Включает стандартную телеметрию Windows"/>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>

                <!-- Система -->
                <GroupBox Header="Система" Margin="0,0,0,10" Padding="10">
                    <UniformGrid Columns="2">
                        <Button Content="Ускорить закрытие" Click="OptimizeSpeed_Click" Margin="5" Height="35" ToolTip="Уменьшает время ожидания при выключении ПК"/>
                        <Button Content="Очистить Кэш Temp" Click="CleanTemp_Click" Margin="5" Height="35" ToolTip="Удаляет временные файлы из папок Temp"/>
                    </UniformGrid>
                </GroupBox>

                <!-- Kill Switch -->
                <Button Content="ЗАВЕРШИТЬ ЗАВИСШИЕ ПРОЦЕССЫ" 
                        Background="#CC0000" Foreground="White" FontWeight="Bold" FontSize="14"
                        Height="60" Click="InstantKill_Click" Margin="0,15,0,15">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>